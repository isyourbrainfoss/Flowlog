<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Flowlog"
        android:textColor="@color/flowlog_crema"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/widget_sparkline"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_weight="1"
        android:contentDescription="@string/widget_sparkline_description"
        android:scaleType="fitXY" />

    <TextView
        android:id="@+id/widget_tap_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_tap_to_open"
        android:textColor="@color/flowlog_outline"
        android:textSize="12sp" />
</LinearLayout>